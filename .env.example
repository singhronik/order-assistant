# Copy this file to .env and fill in real values. Never commit the real .env.

# Base URL of your running Django Order Management System API
DJANGO_API_BASE_URL=http://127.0.0.1:8000/api

# "gemini" (has a free tier), "anthropic", or "openai"
LLM_PROVIDER=gemini

# Only one of these needs to be set, matching LLM_PROVIDER above
GOOGLE_API_KEY=your-gemini-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here
OPENAI_API_KEY=your-openai-api-key-here
